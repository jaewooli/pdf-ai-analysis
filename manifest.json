{
  "manifest_version": 3,
  "name": "PDF AI Analyzer Pro",
  "version": "1.0",
  "description": "PDF 요약 및 원문 하이라이팅 확장 프로그램",
  "permissions": [
    "activeTab",
    "sidePanel",
    "webNavigation",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "분석 패널 열기",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "lib/*"],
      "matches": ["<all_urls>"]
    }
  ]
}